{
  "manifest_version": 3,
  "name": "Quick Translate",
  "version": "1.0.0",
  "description": "마우스로 선택한 텍스트를 즉시 번역",
  "permissions": ["storage"],
  "host_permissions": [
    "https://translation.googleapis.com/*",
    "https://api.datamuse.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "toggle-enabled": {
      "suggested_key": {
        "default": "Alt+T",
        "mac": "Alt+T"
      },
      "description": "Quick Translate 활성/비활성화"
    }
  },
  "options_page": "options.html",
  "action": {
    "default_title": "Quick Translate 설정",
    "default_popup": "options.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
